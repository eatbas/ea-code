{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EA Code",
  "version": "0.2.1",
  "identifier": "com.eatbas.ea-code",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyN0NEQzlCRDY5MkM0NkYKUldSdnhKTFdtOXg4TXVvblRLSFpqTEpFM0ZUaXhjcnkxbENlcTB6MmpmRzhLTGpmRHhNYkU5L3MK",
      "endpoints": [
        "https://ea-code.atbas.xyz/api/v1/updates/latest.json"
      ]
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EA Code — AI Orchestrator",
        "center": true,
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
